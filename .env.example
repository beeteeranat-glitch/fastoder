# Supabase — copy จาก Vercel (Settings → Environment Variables)
# หรือ Supabase Dashboard → Settings → API
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ใช้ฝั่ง server เท่านั้น (API routes) — ห้ามใส่ NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ลงนาม session ลูกค้า (ถ้าไม่ใส่จะใช้ service role key)
# CUSTOMER_SESSION_SECRET=your-random-secret

# รหัสผ่าน: Supabase Dashboard → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-database-password
# หรือ Personal Access Token (npm run db:migrate:008): https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# หรือ connection string เต็ม:
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
